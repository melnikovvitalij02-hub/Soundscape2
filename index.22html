<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>SoundScape: Cyberpunk Edition</title>
    <style>
        :root {
            --bg: #050505;
            --primary: #00f3ff;
            --secondary: #bc13fe;
            --success: #00ff41;
            --danger: #ff0040;
            --warning: #ffaa00;
            --glass: rgba(20, 20, 30, 0.7);
            --border: rgba(255, 255, 255, 0.1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Courier New', monospace; -webkit-tap-highlight-color: transparent; user-select: none; }

        body {
            background-color: var(--bg);
            background-image:
                linear-gradient(rgba(0, 243, 255, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 243, 255, 0.03) 1px, transparent 1px);
            background-size: 30px 30px;
            color: #fff;
            min-height: 100vh;
            padding: 20px;
            padding-bottom: 100px;
            overflow-x: hidden;
        }

        /* HEADER */
        header {
            text-align: center;
            margin-bottom: 30px;
            position: relative;
        }
        .logo {
            font-size: 36px;
            font-weight: 900;
            letter-spacing: 3px;
            text-shadow: 0 0 10px var(--primary), 0 0 20px var(--secondary);
            display: inline-block;
            animation: logoGlow 3s ease-in-out infinite;
        }
        @keyframes logoGlow { 0%, 100% { opacity: 1; } 50% { opacity: 0.8; } }

        .status-bar {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin-top: 15px;
            font-size: 14px;
            color: var(--primary);
            text-shadow: 0 0 10px var(--primary);
        }
        .stat { background: rgba(0, 243, 255, 0.1); padding: 5px 15px; border-radius: 20px; border: 1px solid var(--primary); }

        /* TABS */
        .tabs { display: flex; justify-content: center; gap: 15px; margin-bottom: 25px; position: sticky; top: 0; z-index: 100; background: rgba(5,5,5,0.9); padding: 10px 0; backdrop-filter: blur(10px); }
        .tab-btn {
            background: transparent;
            border: 1px solid var(--border);
            color: #888;
            padding: 12px 25px;
            border-radius: 30px;
            cursor: pointer;
            transition: all 0.3s;
            text-transform: uppercase;
            font-size: 13px;
            letter-spacing: 1px;
            font-weight: bold;
        }
        .tab-btn:hover { border-color: var(--primary); color: var(--primary); }
        .tab-btn.active {
            border-color: var(--primary);
            color: var(--primary);
            box-shadow: 0 0 20px rgba(0, 243, 255, 0.4);
            background: rgba(0, 243, 255, 0.1);
            transform: translateY(-2px);
        }

        .section { display: none; animation: fadeIn 0.5s; }
        .section.active { display: block; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

        /* PLAYER CONTAINER */
        .player-container {
            background: var(--glass);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 30px;
            text-align: center;
            backdrop-filter: blur(15px);
            box-shadow: 0 0 40px rgba(0,0,0,0.6);
            position: relative;
            overflow: hidden;
            margin-bottom: 25px;
        }
        .player-container::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
            background: linear-gradient(90deg, transparent, var(--primary), var(--secondary), transparent);
            animation: scanline 3s linear infinite;
        }
        @keyframes scanline { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }

        .cover {
            width: 180px; height: 180px;
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            border-radius: 50%;
            margin: 0 auto 25px;
            display: flex; align-items: center; justify-content: center;
            font-size: 80px;
            border: 3px solid var(--primary);
            box-shadow: 0 0 30px rgba(0, 243, 255, 0.3), inset 0 0 30px rgba(0, 243, 255, 0.1);
            position: relative;
            animation: float 6s ease-in-out infinite;
        }
        .cover::after {
            content: ''; position: absolute; width: 100%; height: 100%; border-radius: 50%;
            border: 3px dashed var(--secondary);
            animation: spin 20s linear infinite;
        }
        @keyframes spin { 100% { transform: rotate(360deg); } }
        @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }

        .track-info h2 { font-size: 24px; margin-bottom: 8px; text-shadow: 0 0 10px var(--primary); letter-spacing: 1px; }
        .track-info p { color: var(--secondary); font-size: 15px; font-weight: bold; }

        /* CONTROLS */
        .controls { display: flex; justify-content: center; gap: 25px; margin: 30px 0; align-items: center; }
        .btn {
            background: transparent; border: 2px solid var(--primary); color: var(--primary);
            width: 55px; height: 55px; border-radius: 50%; cursor: pointer;
            font-size: 20px; transition: all 0.2s; display: flex; align-items: center; justify-content: center;
            box-shadow: 0 0 15px rgba(0, 243, 255, 0.2);
        }
        .btn:hover { transform: scale(1.1); box-shadow: 0 0 25px rgba(0, 243, 255, 0.5); }
        .btn:active { transform: scale(0.95); }
        .btn.play {
            width: 80px; height: 80px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: #000;
            font-size: 28px;
            box-shadow: 0 0 30px rgba(0, 243, 255, 0.6);
            border: none;
            animation: pulse 2s infinite;
        }
        @keyframes pulse { 0%, 100% { box-shadow: 0 0 30px rgba(0, 243, 255, 0.6); } 50% { box-shadow: 0 0 50px rgba(0, 243, 255, 0.9); } }

        /* MINI GAME */
        .game-area {
            display: flex;
            flex-direction: column;
            align-items: center;
            margin-top: 30px;
            padding: 20px;
            background: rgba(0,0,0,0.3);
            border-radius: 15px;
            border: 1px solid var(--border);
        }
        .tap-zone {
            width: 140px; height: 140px;
            border-radius: 50%;
            border: 3px solid var(--primary);
            display: flex; align-items: center; justify-content: center;
            font-size: 50px;
            cursor: pointer;
            background: radial-gradient(circle, rgba(0,243,255,0.2), transparent);
            transition: all 0.1s;
            position: relative;
            overflow: hidden;
            box-shadow: 0 0 30px rgba(0, 243, 255, 0.3);
        }
        .tap-zone::before {
            content: ''; position: absolute; width: 100%; height: 100%;
            background: radial-gradient(circle, rgba(0,243,255,0.4), transparent);
            opacity: 0; transition: opacity 0.1s;
        }
        .tap-zone:active { transform: scale(0.85); }
        .tap-zone:active::before { opacity: 1; }
        .tap-zone.pulse { animation: beatPulse 0.6s infinite; }
        @keyframes beatPulse { 0% { transform: scale(1); box-shadow: 0 0 30px rgba(0, 243, 255, 0.3); } 50% { transform: scale(1.15); box-shadow: 0 0 60px rgba(0, 243, 255, 0.8); } 100% { transform: scale(1); box-shadow: 0 0 30px rgba(0, 243, 255, 0.3); } }

        .energy-display {
            margin-top: 20px;
            font-size: 24px;
            color: var(--success);
            font-weight: bold;
            text-shadow: 0 0 15px var(--success);
            letter-spacing: 2px;
        }
        .combo { font-size: 16px; color: var(--warning); height: 30px; margin-top: 10px; font-weight: bold; text-shadow: 0 0 10px var(--warning); }
        .combo.fire { color: #ff4400; animation: firePulse 0.3s infinite; }
        @keyframes firePulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.1); } }

        .instructions { font-size: 12px; color: #666; margin-top: 15px; text-align: center; line-height: 1.6; }

        /* MAP GRID */
        .map-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 25px;
            padding: 20px;
        }
        .node {
            background: rgba(0,0,0,0.5);
            border: 2px solid var(--border);
            border-radius: 20px;
            padding: 25px;
            text-align: center;
            position: relative;
            transition: all 0.3s;
            overflow: hidden;
        }
        .node::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0;
            background: radial-gradient(circle at center, rgba(0,243,255,0.1), transparent);
            opacity: 0; transition: opacity 0.3s;
        }
        .node:hover::before { opacity: 1; }
        .node.locked { opacity: 0.5; filter: grayscale(1); }
        .node.unlocked {
            border-color: var(--success);
            box-shadow: 0 0 30px rgba(0, 255, 65, 0.3);
            transform: translateY(-5px);
        }
        .node.unlocked-anim { animation: nodeUnlock 1s ease-out; }
        @keyframes nodeUnlock { 0% { transform: scale(0.8); opacity: 0; } 50% { transform: scale(1.1); box-shadow: 0 0 50px rgba(0,255,65,1); } 100% { transform: scale(1); opacity: 1; } }

        .node-icon { font-size: 40px; margin-bottom: 15px; position: relative; z-index: 1; }
        .node-name { font-weight: bold; color: #fff; margin-bottom: 10px; font-size: 16px; position: relative; z-index: 1; }
        .node-cost {
            font-size: 13px; color: var(--secondary); font-weight: bold; margin-bottom: 10px;
            background: rgba(188, 19, 254, 0.2); padding: 6px 12px; border-radius: 8px; display: inline-block;
            border: 1px solid var(--secondary);
            position: relative; z-index: 1;
        }
        .unlock-btn {
            background: linear-gradient(135deg, var(--secondary), var(--primary));
            border: none;
            color: #000;
            padding: 10px 20px;
            border-radius: 10px;
            cursor: pointer;
            font-weight: bold;
            font-size: 13px;
            transition: all 0.3s;
            position: relative; z-index: 1;
            box-shadow: 0 0 20px rgba(188, 19, 254, 0.4);
        }
        .unlock-btn:hover { transform: scale(1.05); box-shadow: 0 0 30px rgba(188, 19, 254, 0.7); }
        .unlock-btn:active { transform: scale(0.95); }
        .unlock-btn:disabled { background: #333; color: #666; cursor: not-allowed; transform: none; }
        .node-status { color: var(--success); margin-top: 10px; font-weight: bold; font-size: 14px; position: relative; z-index: 1; }

        /* PROGRESS BAR */
        .progress-container {
            width: 100%;
            max-width: 400px;
            margin: 20px auto;
            padding: 0 20px;
        }
        .progress-bar {
            width: 100%;
            height: 8px;
            background: rgba(255,255,255,0.1);
            border-radius: 4px;
            overflow: hidden;
            position: relative;
        }
        .progress-fill {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
            border-radius: 4px;
            transition: width 0.1s linear;
            box-shadow: 0 0 10px var(--primary);
        }
        .time-display {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            color: #888;
            margin-top: 8px;
        }

        /* NOTIFICATIONS */
        .notification {
            position: fixed;
            top: 20px;
            right: 20px;
            background: var(--glass);
            border: 2px solid var(--success);
            color: var(--success);
            padding: 15px 25px;
            border-radius: 10px;
            box-shadow: 0 0 30px rgba(0,255,65,0.4);
            transform: translateX(400px);
            transition: transform 0.3s;
            z-index: 1000;
            font-weight: bold;
        }
        .notification.show { transform: translateX(0); }
        .notification.error { border-color: var(--danger); color: var(--danger); box-shadow: 0 0 30px rgba(255,0,64,0.4); }

        /* SCROLLBAR */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: rgba(0,0,0,0.3); border-radius: 4px; }
        ::-webkit-scrollbar-thumb { background: var(--primary); border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--secondary); }

        /* RESPONSIVE */
        @media (max-width: 600px) {
            .logo { font-size: 28px; }
            .cover { width: 140px; height: 140px; font-size: 60px; }
            .btn.play { width: 70px; height: 70px; font-size: 24px; }
            .tap-zone { width: 120px; height: 120px; font-size: 40px; }
            .map-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <header>
        <div class="logo">SOUND<span style="color:var(--secondary)">SCAPE</span></div>
        <div class="status-bar">
            <div class="stat">⚡ <span id="energy-val">0</span></div>
            <div class="stat">🎵 <span id="track-num">1</span>/<span id="track-total">3</span></div>
        </div>
    </header>

    <div class="tabs">
        <button class="tab-btn active" onclick="switchTab('game')">🎮 Игра</button>
        <button class="tab-btn" onclick="switchTab('map')">🗺️ Карта</button>
    </div>

    <!-- GAME / PLAYER TAB -->
    <div id="game" class="section active">
        <div class="player-container">
            <div class="cover" id="cover-icon">🎧</div>
            <div class="track-info">
                <h2 id="track-title">Neon Drive</h2>
                <p id="track-artist">Cyber Pulse</p>
            </div>

            <div class="progress-container">
                <div class="progress-bar" onclick="seekTrack(event)">
                    <div class="progress-fill" id="progress-fill"></div>
                </div>
                <div class="time-display">
                    <span id="current-time">0:00</span>
                    <span id="total-time">0:00</span>
                </div>
            </div>

            <div class="controls">
                <button class="btn" onclick="prevTrack()">⏮</button>
                <button class="btn play" onclick="togglePlay()" id="play-btn">▶</button>
                <button class="btn" onclick="nextTrack()">⏭</button>
            </div>

            <!-- MINI GAME -->
            <div class="game-area">
                <div class="combo" id="combo-text"></div>
                <div class="tap-zone" id="tap-btn" onclick="tapRhythm()">⚡</div>
                <div class="energy-display">⚡ <span id="energy-display">0</span></div>
                <p class="instructions">🎯 Тапай в ритм музыки!<br>🔥 Набирай комбо для бонусов<br>💰 Трать энергию на открытие зон</p>
            </div>
        </div>
    </div>

    <!-- MAP TAB -->
    <div id="map" class="section">
        <div class="map-grid" id="map-grid">
            <!-- Nodes generated by JS -->
        </div>
    </div>

    <!-- NOTIFICATION -->
    <div class="notification" id="notification"></div>

    <audio id="audio" preload="metadata"></audio>

    <script>
        // ==================== DATA ====================
        const tracks = [
            { title: "Neon Drive", artist: "Cyber Pulse", url: "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3", icon: "🌃" },
            { title: "System Failure", artist: "Glitch Mob", url: "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-2.mp3", icon: "👾" },
            { title: "Data Stream", artist: "Binary Sun", url: "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-3.mp3", icon: "💾" },
            { title: "Cyber Heart", artist: "Neon Dreams", url: "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-4.mp3", icon: "💜" },
            { title: "Mainframe", artist: "Code Breaker", url: "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-5.mp3", icon: "🖥️" }
        ];

        const mapZones = [
            { id: 1, name: "Start Node", icon: "🏠", cost: 0, unlocked: true },
            { id: 2, name: "Neon District", icon: "🌃", cost: 50, unlocked: false },
            { id: 3, name: "Glitch City", icon: "👾", cost: 150, unlocked: false },
            { id: 4, name: "Mainframe", icon: "🖥️", cost: 300, unlocked: false },
            { id: 5, name: "Deep Web", icon: "🕸️", cost: 500, unlocked: false },
            { id: 6, name: "Cyber Core", icon: "🔮", cost: 1000, unlocked: false }
        ];

        // ==================== STATE ====================
        let currentTrack = 0;
        let isPlaying = false;
        let energy = parseInt(localStorage.getItem('ss_energy')) || 0;
        let combo = 0;
        let lastTap = 0;
        let comboResetTimer;

        // ==================== INITIALIZATION ====================
        window.addEventListener('load', function() {
            loadProgress();
            updateEnergyUI();
            renderMap();
            loadTrack(0);
            document.getElementById('track-total').textContent = tracks.length;

            // Audio events
            const audio = document.getElementById('audio');
            audio.addEventListener('timeupdate', updateProgress);
            audio.addEventListener('ended', nextTrack);
            audio.addEventListener('loadedmetadata', updateDuration);
        });

        function loadProgress() {
            const savedZones = JSON.parse(localStorage.getItem('ss_zones'));
            if (savedZones) {
                savedZones.forEach((unlocked, idx) => {
                    if (mapZones[idx]) mapZones[idx].unlocked = unlocked;
                });
            }
        }

        function saveProgress() {
            localStorage.setItem('ss_energy', energy);
            localStorage.setItem('ss_zones', JSON.stringify(mapZones.map(z => z.unlocked)));
        }

        // ==================== TABS ====================
        function switchTab(tab) {
            document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById(tab).classList.add('active');
            event.target.classList.add('active');
        }

        // ==================== PLAYER ====================
        function loadTrack(index) {
            const t = tracks[index];
            document.getElementById('track-title').textContent = t.title;
            document.getElementById('track-artist').textContent = t.artist;
            document.getElementById('cover-icon').textContent = t.icon;
            document.getElementById('audio').src = t.url;
            document.getElementById('track-num').textContent = index + 1;
            document.getElementById('progress-fill').style.width = '0%';
            document.getElementById('current-time').textContent = '0:00';
        }

        function togglePlay() {
            const audio = document.getElementById('audio');
            const btn = document.getElementById('play-btn');
            const tapZone = document.getElementById('tap-btn');

            if (isPlaying) {
                audio.pause();
                btn.textContent = '▶';
                tapZone.classList.remove('pulse');
                document.getElementById('combo-text').textContent = '';
                isPlaying = false;
            } else {
                audio.play();
                btn.textContent = '⏸';
                tapZone.classList.add('pulse');
                isPlaying = true;
                showNotification('🎵 Now Playing: ' + tracks[currentTrack].title);
            }
        }

        function nextTrack() {
            currentTrack = (currentTrack + 1) % tracks.length;
            loadTrack(currentTrack);
            if (isPlaying) document.getElementById('audio').play();
        }

        function prevTrack() {
            currentTrack = (currentTrack - 1 + tracks.length) % tracks.length;
            loadTrack(currentTrack);
            if (isPlaying) document.getElementById('audio').play();
        }

        function seekTrack(event) {
            const audio = document.getElementById('audio');
            const progressBar = event.currentTarget;
            const clickPosition = (event.offsetX / progressBar.offsetWidth);
            audio.currentTime = clickPosition * audio.duration;
        }

        function updateProgress() {
            const audio = document.getElementById('audio');
            if (audio.duration) {
                const progress = (audio.currentTime / audio.duration) * 100;
                document.getElementById('progress-fill').style.width = progress + '%';
                document.getElementById('current-time').textContent = formatTime(audio.currentTime);
            }
        }

        function updateDuration() {
            const audio = document.getElementById('audio');
            document.getElementById('total-time').textContent = formatTime(audio.duration);
        }

        function formatTime(seconds) {
            if (isNaN(seconds)) return '0:00';
            const mins = Math.floor(seconds / 60);
            const secs = Math.floor(seconds % 60);
            return `${mins}:${secs.toString().padStart(2, '0')}`;
        }

        // ==================== MINI GAME ====================
        function tapRhythm() {
            if (!isPlaying) {
                showNotification('⚠️ Сначала включи музыку!', true);
                return;
            }

            const now = Date.now();
            if (now - lastTap < 150) return;
            lastTap = now;

            const btn = document.getElementById('tap-btn');
            const comboText = document.getElementById('combo-text');

            if (navigator.vibrate) navigator.vibrate(30);

            btn.style.transform = 'scale(0.85)';
            setTimeout(() => btn.style.transform = 'scale(1)', 100);

            combo++;
            const reward = 1 + Math.floor(combo / 5);
            energy += reward;

            updateEnergyUI();

            if (combo > 20) {
                comboText.textContent = `🔥 MEGA COMBO x${combo}! +${reward}⚡`;
                comboText.className = 'combo fire';
            } else if (combo > 10) {
                comboText.textContent = `⚡ COMBO x${combo}! +${reward}⚡`;
                comboText.className = 'combo';
                comboText.style.color = 'var(--warning)';
            } else {
                comboText.textContent = `+${reward}⚡`;
                comboText.className = 'combo';
                comboText.style.color = 'var(--primary)';
            }

            clearTimeout(comboResetTimer);
            comboResetTimer = setTimeout(() => {
                combo = 0;
                comboText.textContent = '';
            }, 2000);
        }

        function updateEnergyUI() {
            document.getElementById('energy-val').textContent = energy;
            document.getElementById('energy-display').textContent = energy;
            saveProgress();
        }

        // ==================== MAP ====================
        function renderMap() {
            const grid = document.getElementById('map-grid');
            grid.innerHTML = '';

            mapZones.forEach((zone, index) => {
                const node = document.createElement('div');
                node.className = 'node ' + (zone.unlocked ? 'unlocked' : 'locked');

                let actionHTML = '';
                if (!zone.unlocked) {
                    const canAfford = energy >= zone.cost;
                    actionHTML = `
                        <div class="node-cost">${zone.cost}⚡</div>
                        <button onclick="unlockZone(${index})" class="unlock-btn" ${!canAfford ? 'disabled' : ''}>
                            ${canAfford ? 'UNLOCK' : 'Need Energy'}
                        </button>`;
                } else {
                    actionHTML = `<div class="node-status">✅ ACCESSED</div>`;
                }

                node.innerHTML = `
                    <div class="node-icon">${zone.icon}</div>
                    <div class="node-name">${zone.name}</div>
                    ${actionHTML}
                `;
                grid.appendChild(node);
            });
        }

        function unlockZone(index) {
            const zone = mapZones[index];
            if (energy >= zone.cost) {
                energy -= zone.cost;
                zone.unlocked = true;
                saveProgress();
                updateEnergyUI();
                renderMap();

                const node = document.querySelectorAll('.node')[index];
                node.classList.add('unlocked-anim');
                setTimeout(() => node.classList.remove('unlocked-anim'), 1000);

                showNotification(`🎉 ZONE UNLOCKED: ${zone.name}!`);
            } else {
                showNotification(`❌ Need ${zone.cost}⚡! You have ${energy}⚡`, true);
            }
        }

        // ==================== NOTIFICATIONS ====================
        function showNotification(text, isError = false) {
            const notif = document.getElementById('notification');
            notif.textContent = text;
            notif.className = 'notification' + (isError ? ' error' : '');
            notif.classList.add('show');

            setTimeout(() => {
                notif.classList.remove('show');
            }, 3000);
        }

        // ==================== KEYBOARD CONTROLS ====================
        document.addEventListener('keydown', e => {
            if (e.code === 'Space' && e.target.tagName !== 'INPUT') {
                e.preventDefault();
                togglePlay();
            }
            if (e.code === 'ArrowRight' && e.ctrlKey) nextTrack();
            if (e.code === 'ArrowLeft' && e.ctrlKey) prevTrack();
            if (e.code === 'ArrowUp' && isPlaying) tapRhythm();
        });
    </script>
</body>
</html>
